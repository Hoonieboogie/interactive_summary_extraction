<script	type="text/javascript">
function onBxRun()
{   
	if (window.apnExeFile){
		if (apn.widgetMap) apn.widgetMap();
		
		var exeModule = apn.Project.getExeModule(apnExeFile);
		var exe = new exeModule(null, undefined, undefined, {standAlone:true, eventSystem:2}).create();

		exe.init(true);
		exe.load(apnExeFile);
		if (bx.$getParamFromURL(location.href, 'PGO')){
			exe.run(undefined,undefined,parseInt(bx.$getParamFromURL(location.href, 'PGO')));
		}
		else{
			exe.run();
		}

		window.sgg$exe = exe;
		//%%INFO sgg$GetCurrentPageName()´Â ŔĚ ˝ĂÁˇ ŔĚČÄ·Î ŔŻČżÇÔ
	}
	else{
		console.error('[Aspen] Cannot find data file!');
	}
}

function sgg$GetCurrentPageName()/*String|null*/
{
	if (window.sgg$exe && sgg$exe.project && sgg$exe.getCurrentPageID() !== null){
		return apn.Project.getPageTitle(sgg$exe.project, sgg$exe.getCurrentPageID());
	}
	return null;
}

function load()
{
	function run()
	{
		bx.Loader.load({UXoptions:{resize:'resize'}});
	}

	if (window.apnExeFile && apnExeFile.layouts[1].property && apnExeFile.layouts[1].property.CExe && apnExeFile.layouts[1].property.CExe.splash && (apnExeFile.layouts[1].property.CExe.splash.bgClr || apnExeFile.layouts[1].property.CExe.splash.img.mediaID)){
		if (apnExeFile.layouts[1].property.CExe.splash.bgClr){
			document.body.style.backgroundColor = apnExeFile.layouts[1].property.CExe.splash.bgClr;
		}
		if (apnExeFile.layouts[1].property.CExe.splash.img.mediaID){
			document.body.style.backgroundImage = 'url('+apnExeFile.layouts[1].property.CExe.splash.img.mediaID+')';
			document.body.style.backgroundPosition = 'center center';
			document.body.style.backgroundRepeat = 'no-repeat';
			document.body.style.backgroundSize = (apnExeFile.layouts[1].property.CExe.splash.w||40)+'% auto';
			document.body.style.backgroundAttachment = 'fixed';
		}

		if	(window.navigator && (navigator.userAgent.toLowerCase().indexOf("msie") != -1 || navigator.userAgent.toLowerCase().indexOf("trident") != -1)){
			setTimeout(run, 150);
		}
		else{
			setTimeout(run, 0);
		}
	}
	else{
		run();
	}
}
</script>

