# Backend: "vllm" (RunPod local) or "gemini" (API fallback for testing)
BACKEND=vllm

# vLLM local server (RunPod)
VLLM_BASE_URL=http://localhost:8000/v1
# Models for comparison (change per run, or use run_compare.sh)
# VLLM_MODEL=Qwen/Qwen3.5-35B-A3B
# VLLM_MODEL=LGAI-EXAONE/EXAONE-4.0-32B
# VLLM_MODEL=Qwen/Qwen3-32B
VLLM_MODEL=Qwen/Qwen3.5-35B-A3B

# Gemini API (fallback for local testing without GPU)
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Pipeline config
MAX_CHARS=400000
CONCURRENCY=4
